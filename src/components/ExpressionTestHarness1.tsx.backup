import { useState, useEffect, useRef } from "react";
import * as PIXI from "pixi.js";
import { Application } from "pixi.js";
import { getCurrentWindow } from "@tauri-apps/api/window";

import * as _live2dNS from "pixi-live2d-display-advanced/cubism4";
const _live2d = _live2dNS as unknown as typeof import("pixi-live2d-display-advanced");
const Live2DModel = _live2d.Live2DModel;
_live2d.config.sound = false;

type ModelWithTransform = InstanceType<typeof Live2DModel> & {
  position: { set(x: number, y: number): void };
  scale: { set(s: number): void };
  anchor: { set(x: number, y: number): void };
};

const EXPRESSION_GROUPS = [
  { label: "Happy", color: "#f59e0b", expressions: ["happy", "soft_smile", "excited", "celebrate", "closed_eye_smile"] },
  { label: "Neutral/Cognitive", color: "#6366f1", expressions: ["idle_neutral", "curious", "thinking", "focused"] },
  { label: "Negative", color: "#ef4444", expressions: ["angry", "annoyed", "disgusted"] },
  { label: "Emotional", color: "#8b5cf6", expressions: ["sad", "crying", "tear_drop", "embarrassed", "proud", "surprised"] },
  { label: "Sleep States", color: "#0ea5e9", expressions: ["sleepy", "sleep", "wake_up"] },
  { label: "Events", color: "#10b981", expressions: ["notification", "ai_waiting", "ai_completed", "typing", "dragged", "thrown", "low_battery", "friend_online"] },
  { label: "Built-in Params", color: "#f97316", expressions: ["squint_xx"] },
];

const MOTION_GROUPS = [
  { group: "Idle", motions: ["idle_breathing", "idle_headbob"] },
  { group: "Reactions", motions: ["reaction_nod", "reaction_shake", "reaction_surprised", "reaction_tap", "reaction_drag", "reaction_drop"] },
  { group: "Sleep", motions: ["sleep_enter", "sleep_loop", "sleep_exit"] },
  { group: "AI", motions: ["ai_thinking_loop", "ai_complete_bounce"] },
  { group: "Celebrate", motions: ["celebrate_jump"] },
  { group: "Typing", motions: ["typing_look"] },
];

const MODEL_PATH = "/assets/character/yachiyo.model3.json";

function patchDrawableRenderOrders(model: any) {
  const coreModel = model?.internalModel?.coreModel;
  if (!coreModel) return;

  const original = coreModel.getDrawableRenderOrders?.bind(coreModel);

  coreModel.getDrawableRenderOrders = () => {
    const existing = original?.();

    if (existing && existing.length) return existing;

    const count = coreModel.getDrawableCount?.() ?? 0;
    const fallback = new Int32Array(count);

    for (let i = 0; i < count; i++) {
      fallback[i] = i;
    }

    return fallback;
  };
}

